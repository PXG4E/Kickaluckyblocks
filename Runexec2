-- ============================================================
--  Animation helpers
-- ============================================================
local FADE_IN  = TweenInfo.new(0.35, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
local FADE_OUT = TweenInfo.new(0.28, Enum.EasingStyle.Quad, Enum.EasingDirection.In)

local function openUI()
    Backdrop.BackgroundTransparency = 1
    Main.GroupTransparency          = 1
    TS:Create(Backdrop, FADE_IN, { BackgroundTransparency = 0.45 }):Play()
    TS:Create(Main,     FADE_IN, { GroupTransparency      = 0 }):Play()
end

local function closeUI(callback)
    isAnimating = true
    TS:Create(Backdrop, FADE_OUT, { BackgroundTransparency = 1 }):Play()
    TS:Create(Main,     FADE_OUT, { GroupTransparency      = 1 }):Play()
    task.delay(0.3, function()
        Gui:Destroy()
        if callback then callback() end
    end)
end

local function minimizeUI()
    if isAnimating or isMinimized then return end
    isAnimating  = true
    isMinimized  = true
    -- Fade out card and backdrop
    TS:Create(Backdrop, FADE_OUT, { BackgroundTransparency = 1 }):Play()
    TS:Create(Main,     FADE_OUT, { GroupTransparency      = 1 }):Play()
    task.delay(0.3, function()
        Main.Visible   = false
        Bubble.Visible = true
        Bubble.GroupTransparency = 1
        TS:Create(Bubble, FADE_IN, { GroupTransparency = 0 }):Play()
        isAnimating = false
    end)
end

local function restoreUI()
    if isAnimating or not isMinimized then return end
    isAnimating = true
    isMinimized = false
    TS:Create(Bubble, FADE_OUT, { GroupTransparency = 1 }):Play()
    task.delay(0.3, function()
        Bubble.Visible = false
        Main.Visible   = true
        TS:Create(Backdrop, FADE_IN, { BackgroundTransparency = 0.45 }):Play()
        TS:Create(Main,     FADE_IN, { GroupTransparency      = 0 }):Play()
        isAnimating = false
    end)
end

-- Hover effects
local function addHover(btn, normalColor, hoverColor)
    btn.MouseEnter:Connect(function()
        TS:Create(btn, TweenInfo.new(0.15), { BackgroundColor3 = hoverColor }):Play()
    end)
    btn.MouseLeave:Connect(function()
        TS:Create(btn, TweenInfo.new(0.15), { BackgroundColor3 = normalColor }):Play()
    end)
end

