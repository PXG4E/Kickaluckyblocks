-- UI Parent Safety
local UI_PARENT = (function()
    local ok, core = pcall(function() return game:GetService("CoreGui") end)
    return (ok and core) or LocalPlayer:WaitForChild("PlayerGui")
end)()

local function notify(text)
    game:GetService("StarterGui"):SetCore("SendNotification", {
        Title = "PXG Hub", Text = text, Duration = 5,
    })
end

-- prevent double execution
if _G.loaderXlinkExecuted then
    notify("Script already running.") return
end

local HWID = (function()
    local ok, id = pcall(function() return game:GetService("RbxAnalyticsService"):GetClientId() end)
    return (ok and id and id ~= "") and id or tostring(LocalPlayer.UserId)
end)()

-- ============================================================
--  Key Save / Load (persists key per hardware)
-- ============================================================
local KEY_FILE = "PXGHub_SavedKey.txt"

local function saveKey(key)
    pcall(function() writefile(KEY_FILE, key) end)
end

local function loadSavedKey()
    local ok, data = pcall(function() return readfile(KEY_FILE) end)
    return (ok and data and data ~= "") and data or nil
end

local function verifyKey(key, callback)
    local url = BASE_URL .. "/api/keys/check?post=" .. POST_SLUG .. "&key=" .. key .. "&hwid=" .. HWID
    local ok, res = pcall(game.HttpGet, game, url, true)
    if ok then
        local data = HttpService:JSONDecode(res)
        callback(data.status == "success" and data.valid, key)
    else
        callback(false, key)
    end
end

-- ============================================================
--  Main Script Execution (embedded directly)
-- ============================================================
local function runMainScript()
    _G.loaderXlinkExecuted = true

    local MacLib = loadstring(game:HttpGet("https://github.com/biggaboy212/Maclib/releases/latest/download/maclib.txt"))()

    -- Mobile detection
    local UIS      = game:GetService("UserInputService")
    local isMobile = UIS.TouchEnabled and not UIS.KeyboardEnabled

    local Window = MacLib:Window({
        Title        = "PXG HUB",
        Subtitle     = "Kick a Lucky Block",
        Size         = isMobile and UDim2.fromOffset(420, 340) or UDim2.fromOffset(868, 650),
        DragStyle    = isMobile and 2 or 1,
        AcrylicBlur  = not isMobile,
        ShowUserInfo = not isMobile,
        Keybind      = Enum.KeyCode.RightControl,
    })
    if isMobile then Window:SetScale(0.62) end

    -- Services
    local RunService       = game:GetService("RunService")
    local Players          = game:GetService("Players")
    local ReplicatedStorage= game:GetService("ReplicatedStorage")
    local TeleportService  = game:GetService("TeleportService")

    -- Session counters (declared early so all closures can capture them)
    local sessionKicks, sessionSells, sessionCollects = 0, 0, 0
    local sessionStart = tick()

    -- Flags
    local Flags = {
        Farm    = false,
        Collect = false,
        Bonus   = false,
        Sell    = false,
        AntiAfk = false,
        TpSpeed = 90,
    }

    local targetCFrame = CFrame.new(699.768311, 8.75000668, 231.199585, 0, 0, 1, 0, 1, -0, -1, 0, 0)
    local net = ReplicatedStorage:WaitForChild("Shared"):WaitForChild("Packages"):WaitForChild("Network")

    -- Platform
    local platform = Instance.new("Part")
    platform.Size      = Vector3.new(10, 1, 10)
    platform.Anchored  = true
    platform.Transparency = 1
    platform.Parent    = workspace
    platform.CanCollide= false

    -- Auto Bonus helper
    local function ClickTargetBonus()
        local playerGui    = Players.LocalPlayer:FindFirstChild("PlayerGui")
        local kickUpgrades = playerGui and playerGui:FindFirstChild("KickUpgrades", true)
        if not kickUpgrades then return end
        local children = kickUpgrades:GetChildren()
        for i = 4, 5 do
            local btn = children[i]
            if btn then
                local target = btn:IsA("ImageButton") and btn or btn:FindFirstChildWhichIsA("ImageButton", true)
                if target and target.Visible then
                    pcall(function()
                        for _, v in pairs(getconnections(target.MouseButton1Click)) do v:Fire() end
                        for _, v in pairs(getconnections(target.Activated)) do v:Fire() end
                    end)
                end
            end
        end
    end

    -- ── Tabs ──────────────────────────────────────────────────
    local TabGroup  = Window:TabGroup()
    local MainTab   = TabGroup:Tab({ Name = "Main Settings" })
    local StatusTab = TabGroup:Tab({ Name = "Status" })

    local MainLeft  = MainTab:Section({ Side = "Left"  })
    local MainRight = MainTab:Section({ Side = "Right" })
    local StatLeft  = StatusTab:Section({ Side = "Left"  })
    local StatRight = StatusTab:Section({ Side = "Right" })

    -- ── Main Left: toggles ────────────────────────────────────
    MainLeft:Toggle({
        Name = "Kick & Claim", Default = false,
        Callback = function(Value)
            Flags.Farm = Value
            if Flags.Farm then
                task.spawn(function()
                    while Flags.Farm do
                        pcall(function()
                            net.rev_KickEvent:FireServer(1)
                            task.wait(0.1)
                            net.rev_Transformed:FireServer()
                            sessionKicks = sessionKicks + 1
                        end)
                        task.wait(0.2)
                    end
                end)
            end
        end,
    })
    MainLeft:Toggle({ Name = "Auto Sell All",     Default = false, Callback = function(v) Flags.Sell    = v end })
    MainLeft:Toggle({ Name = "Auto Bonus",        Default = false, Callback = function(v) Flags.Bonus   = v end })
    MainLeft:Toggle({ Name = "Auto Collect Money",Default = false, Callback = function(v) Flags.Collect = v end })
    MainLeft:Toggle({ Name = "Anti AFK",          Default = false, Callback = function(v) Flags.AntiAfk = v end })

    -- ── Main Right: controls ──────────────────────────────────
    MainRight:Slider({
        Name = "Tween Speed", Default = 90, Minimum = 1, Maximum = 200,
        DisplayMethod = "Round", Precision = 0,
        Callback = function(v) Flags.TpSpeed = math.round(v) end,
    })
    MainRight:Keybind({
        Name = "Toggle UI Keybind", Default = Enum.KeyCode.RightControl,
        Callback  = function(b) Window:SetKeybind(b) end,
        onBinded  = function(b)
            Window:SetKeybind(b)
            Window:Notify({ Title = "PXG Hub", Description = "UI keybind: " .. b.Name, Lifetime = 3 })
        end,
    }, "UIKeybind")
    MainRight:Button({ Name = "Rejoin",     Callback = function() TeleportService:Teleport(game.PlaceId, Players.LocalPlayer) end })
    MainRight:Button({
        Name = "Server Hop",
        Callback = function()
            local Http = game:GetService("HttpService")
            local Api = "https://games.roblox.com/v1/games/"..game.PlaceId.."/servers/Public?sortOrder=Desc&limit=100"
            local Servers = Http:JSONDecode(game:HttpGet(Api))
            for _, s in pairs(Servers.data) do
                if s.playing < s.maxPlayers and s.id ~= game.JobId then
                    TeleportService:TeleportToPlaceInstance(game.PlaceId, s.id)
                    break
                end
            end
        end,
    })
    MainRight:Button({
        Name = "Destroy UI",
        Callback = function()
            _G.loaderXlinkExecuted = nil
            Window:Unload()
        end,
    })

    -- ── Status Tab ────────────────────────────────────────────
    StatLeft:Header({ Name = "Farm Status" })
    local L_Overall = StatLeft:Label({    Text = "Overall  :  Idle"       })
    local L_Farm    = StatLeft:SubLabel({ Text = "Farm     :  Inactive"   })
    local L_Action  = StatLeft:SubLabel({ Text = "Action   :  None"       })
    local L_Dist    = StatLeft:SubLabel({ Text = "Distance :  -- studs"   })

    StatLeft:Divider()
    StatLeft:Header({ Name = "Feature Flags" })
    local L_Sell    = StatLeft:SubLabel({ Text = "Auto Sell    :  Off" })
    local L_Bonus   = StatLeft:SubLabel({ Text = "Auto Bonus   :  Off" })
    local L_Collect = StatLeft:SubLabel({ Text = "Auto Collect :  Off" })
    local L_AFK     = StatLeft:SubLabel({ Text = "Anti AFK     :  Off" })

    StatRight:Header({ Name = "Performance" })
    local L_Speed  = StatRight:Label({    Text = "Tween Speed  :  90"  })
    local L_Ping   = StatRight:SubLabel({ Text = "Ping         :  -- ms" })
    local L_FPS    = StatRight:SubLabel({ Text = "FPS          :  --"    })
    local L_Uptime = StatRight:SubLabel({ Text = "Uptime       :  0s"    })

    StatRight:Divider()
    StatRight:Header({ Name = "Session" })
    local L_Kicks    = StatRight:SubLabel({ Text = "Kicks done   :  0" })
    local L_Sells    = StatRight:SubLabel({ Text = "Sells done   :  0" })
    local L_Collects = StatRight:SubLabel({ Text = "Collects     :  0" })

    -- FPS tracker
    local lastFPS, fpsCount, fpsAccum = 60, 0, 0
    RunService.Heartbeat:Connect(function(dt)
        fpsAccum = fpsAccum + dt
        fpsCount = fpsCount + 1
        if fpsAccum >= 1 then
            lastFPS  = math.round(fpsCount / fpsAccum)
            fpsAccum = 0
            fpsCount = 0
        end
    end)

    -- Status update loop
    task.spawn(function()
        while true do
            local upSec  = math.floor(tick() - sessionStart)
            local upDisp = (math.floor(upSec/60) > 0)
                and (math.floor(upSec/60).."m "..(upSec%60).."s")
                or  (upSec.."s")

            local ping    = 0
            pcall(function()
                ping = math.round(game:GetService("Stats").Network.ServerStatsItem["Data Ping"]:GetValue())
            end)

            local anyActive = Flags.Farm or Flags.Sell or Flags.Bonus or Flags.Collect
            L_Overall:UpdateName("Overall  :  " .. (anyActive and "Running" or "Idle"))

            local char = Players.LocalPlayer.Character
            local root = char and char:FindFirstChild("HumanoidRootPart")
            if Flags.Farm then
                L_Farm:UpdateName("Farm     :  Active")
                if root then
                    local dist = math.round((targetCFrame.Position - root.Position).Magnitude)
                    L_Dist:UpdateName("Distance :  " .. dist .. " studs")
                    L_Action:UpdateName(dist > 2 and "Action   :  Tweening..." or "Action   :  At target")
                else
                    L_Action:UpdateName("Action   :  Waiting...")
                    L_Dist:UpdateName("Distance :  -- studs")
                end
            else
                L_Farm:UpdateName("Farm     :  Inactive")
                L_Action:UpdateName("Action   :  None")
                L_Dist:UpdateName("Distance :  -- studs")
            end

            L_Sell:UpdateName(   "Auto Sell    :  " .. (Flags.Sell    and "On" or "Off"))
            L_Bonus:UpdateName(  "Auto Bonus   :  " .. (Flags.Bonus   and "On" or "Off"))
            L_Collect:UpdateName("Auto Collect :  " .. (Flags.Collect and "On" or "Off"))
            L_AFK:UpdateName(    "Anti AFK     :  " .. (Flags.AntiAfk and "On" or "Off"))

            L_Speed:UpdateName(  "Tween Speed  :  " .. Flags.TpSpeed)
            L_Ping:UpdateName(   "Ping         :  " .. ping .. " ms")
            L_FPS:UpdateName(    "FPS          :  " .. lastFPS)
            L_Uptime:UpdateName( "Uptime       :  " .. upDisp)
            L_Kicks:UpdateName(  "Kicks done   :  " .. sessionKicks)
            L_Sells:UpdateName(  "Sells done   :  " .. sessionSells)
            L_Collects:UpdateName("Collects     :  " .. sessionCollects)

            task.wait(0.5)
        end
    end)

    -- Select Main tab
    MainTab:Select()

    -- Movement Heartbeat
    RunService.Heartbeat:Connect(function(deltaTime)
        local char = Players.LocalPlayer.Character
        local root = char and char:FindFirstChild("HumanoidRootPart")
        if root and Flags.Farm then
            platform.CFrame    = root.CFrame * CFrame.new(0, -6, 0)
            platform.CanCollide= true
            local targetPos  = targetCFrame.Position
            local dist       = (targetPos - root.Position).Magnitude
            if dist > 2 then
                local dir    = (targetPos - root.Position).Unit
                root.Velocity= Vector3.new(0, 0, 0)
                root.CFrame  = root.CFrame + (dir * Flags.TpSpeed * deltaTime)
            end
        else
            platform.CanCollide = false
            platform.CFrame     = CFrame.new(0, -500, 0)
        end
    end)

    -- Bonus loop
    task.spawn(function()
        while true do
            if Flags.Bonus then ClickTargetBonus() end
            task.wait(0.1)
        end
    end)

    -- Sell loop
    task.spawn(function()
        while true do
            if Flags.Sell then
                pcall(function()
                    net:WaitForChild("ref_B_SellAll"):InvokeServer()
                    sessionSells = sessionSells + 1
                end)
            end
            task.wait(0.1)
        end
    end)

    -- Collect loop
    task.spawn(function()
        while true do
            if Flags.Collect then
                pcall(function()
                    for i = 1, 30 do
                        if not Flags.Collect then break end
                        net.rev_B_Collect:FireServer(i)
                        sessionCollects = sessionCollects + 1
                    end
                end)
                task.wait(0.5)
            else
                task.wait(0.1)
            end
        end
    end)

    -- Anti AFK loop
    task.spawn(function()
        local VirtualUser = game:GetService("VirtualUser")
        while true do
            if Flags.AntiAfk then
                pcall(function()
                    Players.LocalPlayer.Idled:Connect(function()
                        VirtualUser:CaptureController()
                        VirtualUser:ClickButton2(Vector2.new())
                    end)
                end)
            end
            task.wait(15)
        end
    end)
end

