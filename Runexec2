addHover(MinBtn,   Color3.fromRGB(28, 30, 45),   Color3.fromRGB(35, 38, 60))
addHover(Bubble,   Color3.fromRGB(68, 110, 255), Color3.fromRGB(88, 128, 255))

-- Start open
openUI()

-- ============================================================
--  Button logic
-- ============================================================
local function onValidKey()
    Verify.Text             = "✓  Access Granted"
    Verify.BackgroundColor3 = Color3.fromRGB(38, 180, 105)
    task.wait(0.7)
    closeUI(runMainScript)
end

local function onInvalidKey()
    Verify.Text             = "✗  Invalid Key"
    Verify.BackgroundColor3 = Color3.fromRGB(200, 55, 55)
    TS:Create(CardStroke, TweenInfo.new(0.15), { Color = Color3.fromRGB(200, 55, 55) }):Play()
    task.wait(1.5)
    Verify.Text             = "Check & Use Key"
    Verify.BackgroundColor3 = Color3.fromRGB(68, 110, 255)
    TS:Create(CardStroke, TweenInfo.new(0.3), { Color = Color3.fromRGB(45, 48, 70) }):Play()
end

MinBtn.MouseButton1Click:Connect(minimizeUI)
BubbleBtn.MouseButton1Click:Connect(restoreUI)

CloseBtn.MouseButton1Click:Connect(function()
    closeUI(nil)
end)

Verify.MouseButton1Click:Connect(function()
    local key = InputBox.Text:gsub("%s+", "")
    if key == "" then return end

    Verify.Text             = "Checking..."
    Verify.BackgroundColor3 = Color3.fromRGB(50, 55, 90)

    verifyKey(key, function(valid)
        if valid then
            saveKey(key)
            onValidKey()
        else
            onInvalidKey()
        end
    end)
end)

GetKey.MouseButton1Click:Connect(function()
    setclipboard(GET_KEY_URL)
    GetKey.Text = "✓  Link Copied!"
    task.delay(1.5, function() GetKey.Text = "Get Key" end)
    notify("Key link copied to clipboard!")
end)

-- ============================================================
--  Auto-login: check for a saved key on startup
-- ============================================================
local savedKey = loadSavedKey()
if savedKey then
    InputBox.Text = savedKey
    Verify.Text   = "Checking saved key..."
    Verify.BackgroundColor3 = Color3.fromRGB(50, 55, 90)
    task.delay(0.7, function()
        verifyKey(savedKey, function(valid)
            if valid then
                notify("Key auto-verified! Welcome back.")
                onValidKey()
            else
                pcall(function() writefile(KEY_FILE, "") end)
                Verify.Text             = "Check & Use Key"
                Verify.BackgroundColor3 = Color3.fromRGB(68, 110, 255)
                InputBox.Text           = ""
                InputBox.PlaceholderText = "Saved key expired — paste a new one"
                notify("Saved key is no longer valid. Please re-enter.")
            end
        end)
    end)
end
